pipeline {
  agent any

  environment {
    AWS_REGION    = 'eu-north-1'
    DR_REGION     = 'eu-west-1'
    APP_DIR       = 'app'
    TF_DIR        = 'terraform/dr-region'
    DB_PASSWORD   = credentials('db-password')
    SLACK_WEBHOOK = credentials('slack-webhook')
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
        echo "Building commit: ${env.GIT_COMMIT[0..7]}"
      }
    }

    stage('Terraform Validate') {
      steps {
        dir(env.TF_DIR) {
          sh 'terraform init -reconfigure'
          sh 'terraform validate'
          sh 'terraform fmt -check'
        }
      }
    }

    stage('Terraform Plan') {
      steps {
        dir(env.TF_DIR) {
          sh """
            terraform plan \
              -var="db_password=${DB_PASSWORD}" \
              -out=tfplan
          """
        }
      }
    }

    stage('Terraform Apply') {
      steps {
        dir(env.TF_DIR) {
          sh 'terraform apply -auto-approve tfplan'
        }
      }
    }

    stage('Deploy Application') {
      steps {
        sh '''
          # Package the app
          cd app && zip -r ../myapp.zip . && cd ..

          # Copy to S3 as deployment artifact
          aws s3 cp myapp.zip \
            s3://myapp-assets-primary-eu-north-1/deployments/myapp.zip \
            --region ${AWS_REGION}

          # Get instance ID from ASG
          INSTANCE_ID=$(aws autoscaling describe-auto-scaling-groups \
            --auto-scaling-group-names multiDR-asg \
            --region ${AWS_REGION} \
            --query 'AutoScalingGroups[0].Instances[0].InstanceId' \
            --output text)

          echo "Deploying to instance: $INSTANCE_ID"

          # Deploy via SSM
          aws ssm send-command \
            --instance-ids $INSTANCE_ID \
            --region ${AWS_REGION} \
            --document-name AWS-RunShellScript \
            --parameters commands='[
              "aws s3 cp s3://myapp-assets-primary-eu-north-1/deployments/myapp.zip /tmp/",
              "unzip -o /tmp/myapp.zip -d /opt/myapp/",
              "cd /opt/myapp && venv/bin/pip install -r requirements.txt -q",
              "sudo systemctl restart myapp"
            ]'
        '''
      }
    }

    stage('Smoke Test') {
      steps {
        sh '''
          echo "Waiting 20 seconds for app to start..."
          sleep 20

          ALB_DNS=$(cd terraform/dr-region && terraform output -raw dr_alb_dns_name)

          HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
            http://${ALB_DNS}/health)

          echo "Health check returned: $HTTP_CODE"

          if [ "$HTTP_CODE" != "200" ]; then
            echo "SMOKE TEST FAILED"
            exit 1
          fi

          echo "Smoke test passed!"
        '''
      }
    }

  }

  post {
    success {
      sh """
        curl -X POST -H 'Content-type: application/json' \
        --data '{"text":"✅ Deploy succeeded | Job: ${env.JOB_NAME} | Commit: ${env.GIT_COMMIT[0..7]} | Region: eu-north-1"}' \
        \${SLACK_WEBHOOK}
      """
    }
    failure {
      sh """
        curl -X POST -H 'Content-type: application/json' \
        --data '{"text":"🔴 Deploy FAILED | Job: ${env.JOB_NAME} | See: ${env.BUILD_URL}"}' \
        \${SLACK_WEBHOOK}
      """
    }
    always {
      cleanWs()
    }
  }

}